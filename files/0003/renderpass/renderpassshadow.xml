			<Element Name="ShadowMaterial" EnableMacroName="SHADOW_MATERIAL" EnumType="Bool" Default="False" Mutable="False" CacheSuffix="sm" TargetShaders="all">
				<Overriding Value="False" DivergentLevel="AsDefined" StateOverrideMethod="Blank"/>
				<Overriding Value="True" DivergentLevel="Material" StateOverrideMethod="Blank"/>
			</Element>
			<Element Name="TwoSided" EnableMacroName="TWO_SIDED" EnumType="Bool" Default="False" CacheSuffix="ts" TargetShaders="all" Mutable="false">
				<PipelineState Type="Blank"></PipelineState>
				<PipelineState Type="Overwrite">
					<CullMode Mode="None" />
				</PipelineState>
			</Element>
		</Permutation>
		<Define Name="NEED_TEXTURE" Value="1" CacheSuffix="nt" TargetShaders="all"/>
		<VertexShader Filename="ObjectShadow.hlsl" EntryPoint="StaticShadowMainVS" CompatibilityFlag="BoundsCheck" />
		<PixelShader Filename="ObjectShadow.hlsl" EntryPoint="StaticShadowMainPS" />
		<DepthState DepthFunc="LessEqual"/>
		<Rasterizer MultiSampleEnable="True" MultiSampleCount="32" SlopeScaledDepthBias="4.0" MultisampleShadow="True"/>
	</Pipeline>

	<Pipeline Pass="TreeShadow8" InputLayout="TreeVertex" IndirectCommandLayout="ObjectIndirectCommand" Condition="MultiDraw|ConditionalRTIndexInVertexOrTessellationShader|ConditionalTextureMSArray">
		<Permutation>
			<Element Name="TreeQualityLevel" EnableMacroName="TREE_QUALITY_LEVEL" EnumType="Integer" Count="2" CacheSuffix="tql" TargetShaders="vs" Material="false" />
		</Permutation>
		<Define Name="RT_INDEX_IN_VS" Value="1" CacheSuffix="ri" TargetShaders="all"/>
		<VertexShader Filename="TreeShadow.hlsl" EntryPoint="TreeSceneShadowVS8_FarShadow_NoGS_Cascaded" />
		<PixelShader Filename="TreeShadow.hlsl" EntryPoint="TreeSceneStaticShadowColorPS" />
		<DepthState DepthFunc="LessEqual"/>
		<CullMode Mode="None" />
		<Rasterizer MultiSampleEnable="True" MultiSampleCount="32" SlopeScaledDepthBias="4.0" MultisampleShadow="True"/>
	</Pipeline>

	<Pipeline Pass="TreeImpostorShadow8" InputLayout="ImpostorVertex" Condition="MultiDraw|ConditionalRTIndexInVertexOrTessellationShader">
		<Define Name="RT_INDEX_IN_VS" Value="1" CacheSuffix="ri" TargetShaders="all"/>
		<VertexShader Filename="TreeShadow.hlsl" EntryPoint="vsImpostorStaticCascadedShadow" />
		<PixelShader Filename="TreeShadow.hlsl" EntryPoint="psImpostorStaticCascadedShadow" />
		<DepthState DepthFunc="LessEqual"/>
		<Rasterizer MultiSampleEnable="True" MultiSampleCount="32" SlopeScaledDepthBias="4.0" MultisampleShadow="True"/>
	</Pipeline>

	<Pipeline Pass="TerrainMesh" InputLayout="ObjectVertex" Condition="MultiDraw|ConditionalRTIndexInVertexOrTessellationShader">
		<Define Name="USE_DRAW_INDEX_AS_MATERIAL_PARAMTERS_VIEW_INDEX" Value="1" CacheSuffix="diamp" TargetShaders="vs|ps" />
		<!--<Permutation>
			<Element Name="UseTessellation" EnableMacroName="USE_TESSELLATION" EnumType="Bool" Default="False" CacheSuffix="utes" Material="True" TargetShaders="all">
				<Overriding StateOverrideMethod="Blank">
