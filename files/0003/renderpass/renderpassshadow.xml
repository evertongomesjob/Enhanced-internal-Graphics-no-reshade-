    <DepthState DepthFunc="LessEqual"/>
    <Rasterizer MultiSampleEnable="True" MultiSampleCount="32" SlopeScaledDepthBias="4.0" MultisampleShadow="True"/>
  </Pipeline>-->

</RenderPass>

<RenderPass Name="SceneDynamicShadowMiscBindless" FrameBuffer="DynamicShadowBindless">
	<Define Name="__XBOX_XIC_ENABLE" Value="1" CacheSuffix="xic" TargetShaders="all" Condition="Xbox"/>

	<Pipeline Pass="DeformableSurfaceTerrainShadow" Condition="!Android" BuildTriggerType="Required">
		<Define Name="SHADOW_PASS" Value="1" CacheSuffix="sp" TargetShaders="hs"/>
		<VertexShader Filename="DeformableSurface.hlsl" EntryPoint="DeformableSurfaceTerrainVS" />
		<HullShader Filename="DeformableSurface.hlsl" EntryPoint="DeformableSurfaceTerrainHS" /> 
		<DomainShader Filename="DeformableSurface.hlsl" EntryPoint="DeformableSurfaceTerrainShadowDS" />
		<GeometryShader Filename="DeformableSurface.hlsl" EntryPoint="DeformableSurfaceDynamicShadowGS" />
		<PixelShader Filename="DeformableSurface.hlsl" EntryPoint="DeformableSurfaceShadowPS" />
		<InputElement Topology="ControlPoint_4">
			<VertexElement Element="Position" Format="R32G32B32_FLOAT" InputClass="Vertex" />
			<VertexElement Element="TexCoord0" Format="R32G32_FLOAT" InputClass="Vertex" />
		</InputElement>
		<DepthState DepthFunc="LessEqual"/>
		<Rasterizer MultiSampleEnable="True" MultiSampleCount="32" SlopeScaledDepthBias="4.0" MultisampleShadow="True"/>
	</Pipeline>
	
	<Pipeline Pass="SubdivisionSurfaceTerrainShadow" InputLayout="Empty">
		<VertexShader Filename="DeformableSurface.hlsl" EntryPoint="SubdivisionSurfaceVS" />
		<PixelShader Filename="DeformableSurface.hlsl" EntryPoint="SubDivisionSurfaceShadowPS" />
		<DepthState DepthFunc="LessEqual"/>
		<Rasterizer MultiSampleEnable="True" MultiSampleCount="32" SlopeScaledDepthBias="4.0" MultisampleShadow="True"/>
	</Pipeline>	

	<Pipeline Pass="DynamicShadowRayMarchingSDFs" InputLayout="FullScreenVertex">
		<VertexShader Filename="ScreenSpaceCommon.hlsl" EntryPoint="FullScreenVS" />
		<PixelShader Filename="RayMarchingSDFs.hlsl" EntryPoint="RayMarchingSDFsForDynamicShadowPS" />
		<DepthState DepthFunc="LessEqual"/>
		<Rasterizer MultiSampleEnable="True" MultiSampleCount="32" SlopeScaledDepthBias="4.0" MultisampleShadow="True"/>
	</Pipeline>
</RenderPass>

<RenderPass Name="SceneDynamicShadowTranslucentBindless" FrameBuffer="DynamicShadowTranslucentBindless" ClearTarget="RenderTargets" ClearColor="1,1,1,1">
	<Define Name="__XBOX_XIC_ENABLE" Value="1" CacheSuffix="xic" TargetShaders="all" Condition="Xbox"/>

	<FrameBufferBinding Name="DynamicShadowTranslucentBindless0" FrameBuffer="DynamicShadowTranslucentBindless0"/>	
	<FrameBufferBinding Name="DynamicShadowTranslucentBindless1" FrameBuffer="DynamicShadowTranslucentBindless1"/>

	<Permutation>
		<Element Name="ViewInstancing" EnableMacroName="VIEW_INSTANCING" EnumType="Bool" Default="False" CacheSuffix="vi" TargetShaders="all" Material="False" Condition="SupportViewInstancing">
			<Overriding StateOverrideMethod="Blank">
			</Overriding>
			<Overriding StateOverrideMethod="Overwrite">
				<GeometryShader />
				<ViewInstancing Count="2" Type="SequentialRenderTarget"/>
			</Overriding>
		</Element>
	</Permutation>
	
	<Pipeline Pass="ObjectShadow" InputLayout="ObjectVertex" Condition="MultiDraw" FrameBufferBindingName="SceneDynamicShadowTranslucentBindless, DynamicShadowTranslucentBindless0, DynamicShadowTranslucentBindless1">
		<Define Name="USE_DRAW_INDEX_AS_MATERIAL_PARAMTERS_VIEW_INDEX" Value="1" CacheSuffix="diamp" TargetShaders="vs|ps" />
		<Permutation>
			<Element Name="ShadowMaterial" EnableMacroName="SHADOW_MATERIAL" EnumType="Bool" Default="False" Mutable="False" CacheSuffix="sm" TargetShaders="all">
				<Overriding Value="False" DivergentLevel="AsDefined" StateOverrideMethod="Blank"/>
				<Overriding Value="True" DivergentLevel="Material" StateOverrideMethod="Blank"/>
			</Element>
		</Permutation>
		<Define Name="NEED_TEXTURE" Value="1" CacheSuffix="nt" TargetShaders="all"/>
		<VertexShader Filename="ObjectShadow.hlsl" EntryPoint="DynamicShadowMainVS" />
		<!--<GeometryShader Filename="ObjectShadow.hlsl" EntryPoint="ObjectSceneDynamicShadowGS" />-->
		<PixelShader Filename="ObjectShadow.hlsl" EntryPoint="DynamicTranslucentShadowMainPS" />
		<DepthState DepthFunc="LessEqual" DepthWrite="False" />
		<StencilState StencilEnable="True" StencilFunc="Always" PassOp="Replace" FailOp="Keep" DepthFailOp="Keep" StencilRefName="SHADOW_MATERIAL_IGNORED_BY_RAYTRACING" />
		<CullMode Mode="None" />
		<Rasterizer MultiSampleEnable="True" MultiSampleCount="32" SlopeScaledDepthBias="4.0" MultisampleShadow="True"/>
		<BlendState AlphaBlend="Multiply"/>
	</Pipeline>
</RenderPass>

<RenderPass Name="SceneShadowBindless" FrameBuffer="StaticShadowBindless" ClearTarget="All" ClearDepth="1.0">
	<Define Name="__XBOX_XIC_ENABLE" Value="1" CacheSuffix="xic" TargetShaders="all" Condition="Xbox"/>

	<Permutation>
		<Element Name="MassPlacement" EnableMacroName="MASS_PLACEMENT" EnumType="Bool" Default="False" CacheSuffix="mp" TargetShaders="vs|ps">
			<PipelineState Type="Blank"></PipelineState>
			<PipelineState Type="Overwrite" >
				<InputLayout From="ObjectVertex" To="ObjectVertexMass"/>
				<InputLayout From="TreeVertex" To="TreeVertexMass"/>
				<InputLayout From="ImpostorVertex" To="ImpostorVertexMass"/>
