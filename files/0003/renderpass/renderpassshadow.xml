<FrameBuffer Name="DynamicShadowBindless0" ForStaticMesh="True">
	<DynamicShadowDepth ViewIndex="1" />
</FrameBuffer>

<FrameBuffer Name="DynamicShadowBindless1" ForStaticMesh="True">
	<DynamicShadowDepth ViewIndex="2" />
</FrameBuffer>

<FrameBuffer Name="DynamicShadowTranslucentBindless0" ForStaticMesh="True">
	<DynamicShadowColor ViewIndex="1" />
	<DynamicShadowDepth ViewIndex="1" />
</FrameBuffer>

<FrameBuffer Name="DynamicShadowTranslucentBindless1" ForStaticMesh="True">
	<DynamicShadowColor ViewIndex="2" />
	<DynamicShadowDepth ViewIndex="2" />
</FrameBuffer>

<RenderPass Name="SceneDynamicShadowBindless" FrameBuffer="DynamicShadowBindless" ClearTarget="All" ClearDepth="1.0" AutoUpdateMaterialConfigs="False">
	<Define Name="__XBOX_XIC_ENABLE" Value="1" CacheSuffix="xic" TargetShaders="all" Condition="Xbox"/>
	<FrameBufferBinding Name="DynamicShadowBindless0" FrameBuffer="DynamicShadowBindless0"/>
	<FrameBufferBinding Name="DynamicShadowBindless1" FrameBuffer="DynamicShadowBindless1"/>

	<Permutation>
		<Element Name="ViewInstancing" EnableMacroName="VIEW_INSTANCING" EnumType="Bool" Default="False" CacheSuffix="vi" TargetShaders="all" Material="False" Condition="SupportViewInstancing">
			<Overriding StateOverrideMethod="Blank">
			</Overriding>
			<Overriding StateOverrideMethod="Overwrite">
				<GeometryShader />
				<ViewInstancing Count="2" Type="SequentialRenderTarget"/>
			</Overriding>
		</Element>
		<Element Name="MassPlacement" EnableMacroName="MASS_PLACEMENT" EnumType="Bool" Default="False" CacheSuffix="mp" TargetShaders="vs" />
	</Permutation>

	<!-- RenderPass ?대쫫?? 湲곕낯 FrameBuffer?? ??묓븯?? FrameBufferBindingName?쇰줈 ?곗씪 ?? ?덉쓬 -->
	<Pipeline Pass="ObjectShadow" InputLayout="ObjectVertex" Condition="MultiDraw" FrameBufferBindingName="SceneDynamicShadowBindless, DynamicShadowBindless0, DynamicShadowBindless1">
		<Define Name="USE_DRAW_INDEX_AS_MATERIAL_PARAMTERS_VIEW_INDEX" Value="1" CacheSuffix="diamp" TargetShaders="vs|ps" />
		<Permutation>
			<Element Name="ClipSkyHoles" EnableMacroName="CLIP_SKY_HOLES" EnumType="Bool" Default="False" CacheSuffix="csh" TargetShaders="vs|ps" Material="False">
				<Overriding Value="True" StateOverrideMethod="Overwrite">
					<PixelShader Filename="ObjectShadow.hlsl" EntryPoint="DynamicShadowMainPS" />
				</Overriding>
			</Element>
			<Element Name="VertexVelocity" EnableMacroName="VERTEX_VELOCITY" EnumType="Bool" Default="False" CacheSuffix="vv" TargetShaders="vs" />
			<Element Name="AlphaTest" EnableMacroName="ALPHA_TEST" EnumType="Bool" Default="False" CacheSuffix="at" TargetShaders="vs|gs|ps">
				<Overriding Value="True" StateOverrideMethod="Overwrite">
					<PixelShader Filename="ObjectShadow.hlsl" EntryPoint="DynamicShadowMainPS" />
				</Overriding>
			</Element>
			<Element Name="ShadowMaterial" EnableMacroName="SHADOW_MATERIAL" EnumType="Bool" Default="False" Mutable="False" CacheSuffix="sm" TargetShaders="all">
				<Overriding Value="False" DivergentLevel="AsDefined" StateOverrideMethod="Blank"/>
				<Overriding Value="True" DivergentLevel="Material" StateOverrideMethod="Blank"/>
			</Element>
			<Element Name="Dynamic" EnableMacroName="IS_DYNAMIC" EnumType="Bool" Default="False" CacheSuffix="dyn" TargetShaders="vs|ps">
				<PipelineState Type="Blank"></PipelineState>
				<PipelineState Type="OverwriteDefault" >
					<StencilRefValueOp OpName="OR" StencilRefName="SHADOW_MATERIAL_IGNORED_BY_RAYTRACING"/>
				</PipelineState>
			</Element>
			<Element Name="TwoSided" EnableMacroName="TWO_SIDED" EnumType="Bool" Default="False" CacheSuffix="ts" TargetShaders="all" Mutable="false">
				<PipelineState Type="Blank"></PipelineState>
				<PipelineState Type="Overwrite">
					<CullMode Mode="None" />
				</PipelineState>
			</Element>
		</Permutation>
		<VertexShader Filename="ObjectShadow.hlsl" EntryPoint="DynamicShadowMainVS" />
		<!--<GeometryShader Filename="ObjectShadow.hlsl" EntryPoint="ObjectSceneDynamicShadowGS" />-->
		<DepthState DepthFunc="LessEqual" />
		<StencilState StencilEnable="True" StencilFunc="Always" PassOp="Replace" FailOp="Keep" DepthFailOp="Keep" StencilRefName="SHADOW_MATERIAL_DEFAULT" />
		<Rasterizer MultiSampleEnable="True" MultiSampleCount="32" SlopeScaledDepthBias="4.0" MultisampleShadow="True"/>
	</Pipeline>
	
	<Pipeline Pass="TreeShadow8" InputLayout="TreeVertex" IndirectCommandLayout="ObjectIndirectCommand" Condition="MultiDraw" FrameBufferBindingName="SceneDynamicShadowBindless, DynamicShadowBindless0, DynamicShadowBindless1">
		<Permutation>
			<Element Name="TreeQualityLevel" EnableMacroName="TREE_QUALITY_LEVEL" EnumType="Integer" Count="2" CacheSuffix="tql" TargetShaders="vs" Material="false" />
		</Permutation>
		<VertexShader Filename="TreeShadow.hlsl" EntryPoint="TreeSceneShadowWindVS8" />
		<!--<GeometryShader Filename="TreeShadow.hlsl" EntryPoint="TreeSceneDynamicShadowGS" />-->
		<PixelShader Filename="TreeShadow.hlsl" EntryPoint="TreeSceneDynamicShadowPS" />
		<DepthState DepthFunc="LessEqual"/>
		<CullMode Mode="None" />
		<Rasterizer MultiSampleEnable="True" MultiSampleCount="32" SlopeScaledDepthBias="4.0" MultisampleShadow="True"/>
	</Pipeline>

	<Pipeline Pass="TreeBranchShadow8" InputLayout="TreeVertex" IndirectCommandLayout="ObjectIndirectCommand" Condition="MultiDraw" FrameBufferBindingName="SceneDynamicShadowBindless, DynamicShadowBindless0, DynamicShadowBindless1">
		<Permutation>
			<Element Name="TreeQualityLevel" EnableMacroName="TREE_QUALITY_LEVEL" EnumType="Integer" Count="2" CacheSuffix="tql" TargetShaders="vs" Material="false" />
		</Permutation>
		<VertexShader Filename="TreeShadow.hlsl" EntryPoint="TreeBranchShadowWindVS8" />
		<!--<GeometryShader Filename="TreeShadow.hlsl" EntryPoint="TreeSceneDynamicShadowGS" />-->
		<DepthState DepthFunc="LessEqual"/>
		<CullMode Mode="Front" />
		<Rasterizer MultiSampleEnable="True" MultiSampleCount="32" SlopeScaledDepthBias="4.0" MultisampleShadow="True"/>
	</Pipeline>

	<Pipeline Pass="TreeFrondShadow8" InputLayout="TreeVertex" IndirectCommandLayout="ObjectIndirectCommand" Condition="MultiDraw" FrameBufferBindingName="SceneDynamicShadowBindless, DynamicShadowBindless0, DynamicShadowBindless1">
		<Permutation>
			<Element Name="TreeQualityLevel" EnableMacroName="TREE_QUALITY_LEVEL" EnumType="Integer" Count="2" CacheSuffix="tql" TargetShaders="vs" Material="false" />
		</Permutation>
		<VertexShader Filename="TreeShadow.hlsl" EntryPoint="TreeFrondShadowWindVS8" />
		<!--<GeometryShader Filename="TreeShadow.hlsl" EntryPoint="TreeSceneDynamicShadowGS" />-->
		<PixelShader Filename="TreeShadow.hlsl" EntryPoint="TreeSceneDynamicShadowPS" />
		<DepthState DepthFunc="LessEqual"/>
		<CullMode Mode="None" />
		<Rasterizer MultiSampleEnable="True" MultiSampleCount="32" SlopeScaledDepthBias="4.0" MultisampleShadow="True"/>
	</Pipeline>

	<Pipeline Pass="TreeLeafShadow8" InputLayout="TreeVertex" IndirectCommandLayout="ObjectIndirectCommand" Condition="MultiDraw|ConditionalTextureMSArray" FrameBufferBindingName="SceneDynamicShadowBindless, DynamicShadowBindless0, DynamicShadowBindless1">
		<Permutation>
			<Element Name="TreeQualityLevel" EnableMacroName="TREE_QUALITY_LEVEL" EnumType="Integer" Count="2" CacheSuffix="tql" TargetShaders="vs" Material="false" />
		</Permutation>
		<Define Name="LEAF_WIND_ANIMATION" Value="1" CacheSuffix="lwa" TargetShaders="vs"/>
		<VertexShader Filename="TreeShadow.hlsl" EntryPoint="TreeLeafShadowWindVS8" />
		<!--<GeometryShader Filename="TreeShadow.hlsl" EntryPoint="TreeSceneDynamicShadowGS" />-->
		<PixelShader Filename="TreeShadow.hlsl" EntryPoint="TreeSceneDynamicShadowPS" />
		<DepthState DepthFunc="LessEqual"/>
		<CullMode Mode="None" />
		<Rasterizer MultiSampleEnable="True" MultiSampleCount="32" SlopeScaledDepthBias="4.0" MultisampleShadow="True"/>
	</Pipeline>

	<Pipeline Pass="TreeImpostorShadow8" InputLayout="ImpostorVertex" Condition="MultiDraw|ConditionalRTIndexInVertexOrTessellationShader" FrameBufferBindingName="SceneDynamicShadowBindless, DynamicShadowBindless0, DynamicShadowBindless1">
		<Define Name="RT_INDEX_IN_VS" Value="1" CacheSuffix="ri" TargetShaders="all"/>
		<VertexShader Filename="TreeShadow.hlsl" EntryPoint="vsImpostorDynamicCascadedShadow" />
		<PixelShader Filename="TreeShadow.hlsl" EntryPoint="psImpostorDynamicCascadedShadow" />
		<DepthState DepthFunc="LessEqual"/>
		<Rasterizer MultiSampleEnable="True" MultiSampleCount="32" SlopeScaledDepthBias="4.0" MultisampleShadow="True"/>
	</Pipeline>

	<Pipeline Pass="TerrainTile" InputLayout="TerrainTileIndexedVertex" FrameBufferBindingName="SceneDynamicShadowBindless, DynamicShadowBindless0, DynamicShadowBindless1" BuildTriggerType="Required">
		<Define Name="USE_DISPLACEMENT" Value="1" CacheSuffix="disp" TargetShaders="all"/>
		<Define Name="DISTANCE_TILE_SCALE_TYPE" Value="0" CacheSuffix="udts" TargetShaders="all"/>
		<Permutation>
			<Element Name="TerrainDebugMode" EnableMacroName="TERRAIN_DEBUG_MODE" EnumType="Bool" Default="False" CacheSuffix="tdm" TargetShaders="vs|ps" Material="False" />
			<Element Name="ClipSkyHoles" EnableMacroName="CLIP_SKY_HOLES" EnumType="Bool" Default="False" CacheSuffix="csh" TargetShaders="vs|ps" Material="False">
				<Overriding Value="True" StateOverrideMethod="Overwrite">
					<PixelShader Filename="TerrainHeight.hlsl" EntryPoint="TerrainTileShadowPSBindlessMain" />
				</Overriding>
			</Element>
		</Permutation>
		<VertexShader Filename="TerrainHeight.hlsl" EntryPoint="TerrainHeightTileDynamicShadowVS" />
		<!--<GeometryShader Filename="TerrainHeight.hlsl" EntryPoint="TerrainTileDynamicShadowGS" />-->
		<!--<PixelShader Filename="TerrainHeight.hlsl" EntryPoint="TerrainTileShadowPSBindlessMain" />-->
		<DepthState DepthFunc="LessEqual"/>
		<CullMode Mode="None" />
		<Rasterizer MultiSampleEnable="True" MultiSampleCount="32" SlopeScaledDepthBias="4.0" MultisampleShadow="True"/>
	</Pipeline>

	<Pipeline Pass="TerrainMesh" InputLayout="ObjectVertex" Condition="MultiDraw" FrameBufferBindingName="SceneDynamicShadowBindless, DynamicShadowBindless0, DynamicShadowBindless1">
		<Define Name="USE_DRAW_INDEX_AS_MATERIAL_PARAMTERS_VIEW_INDEX" Value="1" CacheSuffix="diamp" TargetShaders="vs|ps" />
		<Permutation>
			<Element Name="ClipSkyHoles" EnableMacroName="CLIP_SKY_HOLES" EnumType="Bool" Default="False" CacheSuffix="csh" TargetShaders="vs|ps" Material="False">
				<Overriding Value="True" StateOverrideMethod="Overwrite">
					<PixelShader Filename="ObjectShadow.hlsl" EntryPoint="DynamicShadowMainPS" />
				</Overriding>
			</Element>
			<!--
			<Element Name="UseTessellation" EnableMacroName="USE_TESSELLATION" EnumType="Bool" Default="False" CacheSuffix="utes" Material="True" TargetShaders="all">
				<Overriding StateOverrideMethod="Blank">
				</Overriding>
				<Overriding StateOverrideMethod="Overwrite">
					<InputElement Topology="ControlPoint_3">
						<VertexElement Element="Position" Format="R32G32B32_FLOAT" InputClass="Vertex" />
						<VertexElement Element="TexCoord" Format="R16G16_FLOAT" InputClass="Vertex" />
						<VertexElement Element="Normal" Format="R16G16B16A16_FLOAT" InputClass="Vertex" />
						<VertexElement Element="Tangent" Format="R16G16B16A16_FLOAT" InputClass="Vertex" />
						<VertexElement Element="Color" Format="R8G8B8A8" InputClass="Vertex" />
						<VertexElement Element="BlendIndices0" Format="R32_UINT" InputClass="Instance" />
					</InputElement>
					<VertexShader Filename="TerrainMesh.hlsl" EntryPoint="vsTerrainMeshTessellateShadow"/>
					<HullShader Filename="TerrainMesh.hlsl" EntryPoint="hsTerrainMeshTessellate"/>
					<DomainShader Filename="TerrainMesh.hlsl" EntryPoint="dsTerrainMeshTessellateShadow"/>
					<GeometryShader Filename="TerrainMesh.hlsl" EntryPoint="gsTerrainMeshTessellateDynamicShadow" />
					<PixelShader Filename="TerrainMesh.hlsl" EntryPoint="psTerrainMeshTessellateDynamicShadow"/>
				</Overriding>
			</Element>
			-->
		</Permutation>
		<Define Name="USE_TESSELLATE_HS_TYPE" Value="2" CacheSuffix="utht" TargetShaders="all"/>
		<VertexShader Filename="ObjectShadow.hlsl" EntryPoint="DynamicShadowMainVS" />
		<HullShader />
		<DomainShader />
		<!--<GeometryShader Filename="ObjectShadow.hlsl" EntryPoint="ObjectSceneDynamicShadowGS" />-->
		<!--<PixelShader Filename="ObjectShadow.hlsl" EntryPoint="DynamicShadowMainPS" />-->
		<DepthState DepthFunc="LessEqual"/>
		<CullMode Mode="Front" />
		<Rasterizer MultiSampleEnable="True" MultiSampleCount="32" SlopeScaledDepthBias="4.0" MultisampleShadow="True"/>
	</Pipeline>

  <!--<Pipeline Pass="ObjectTessellateShadow" InputLayout="ObjectTessellateVertex">
    <VertexShader Filename="ObjectShadow.hlsl" EntryPoint="DynamicShadowMainVS" />
    <GeometryShader Filename="ObjectShadow.hlsl" EntryPoint="ObjectSceneDynamicShadowGS" />
