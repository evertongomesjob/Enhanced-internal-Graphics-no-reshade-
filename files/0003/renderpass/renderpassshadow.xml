		<Permutation>
			<Element Name="ShadowMaterial" EnableMacroName="SHADOW_MATERIAL" EnumType="Bool" Default="False" Mutable="False" CacheSuffix="sm" TargetShaders="all">
				<Overriding Value="False" DivergentLevel="AsDefined" StateOverrideMethod="Blank"/>
				<Overriding Value="True" DivergentLevel="Material" StateOverrideMethod="Blank"/>
			</Element>
		</Permutation>
		<!-- <Define Name="USE_TESSELLATE_HS_TYPE" Value="1" CacheSuffix="utht" TargetShaders="all"/> -->
		<Define Name="NEED_TEXTURE" Value="1" CacheSuffix="nt" TargetShaders="all"/>
