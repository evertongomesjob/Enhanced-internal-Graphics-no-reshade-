		<PixelShader Filename="PostProcessLensFlare.hlsl" EntryPoint="GhostsPS" />
	</Pipeline>

	<Pipeline Pass="LensFlareHalo" InputLayout="FullScreenVertex" FrameBufferBindingName="LensFlare">
		<VertexShader Filename="ScreenSpaceCommon.hlsl" EntryPoint="FullScreenVS" />
		<PixelShader Filename="PostProcessLensFlare.hlsl" EntryPoint="HaloPS" />
		<BlendState AlphaBlend="Additive"/>
	</Pipeline>

	<Pipeline Pass="LensFlareBlades" FrameBufferBindingName="LensFlare">
