		<PixelShader Filename="PostProcessLensFlare.hlsl" EntryPoint="GlareMixPS" />
		<BlendState AlphaBlend="Additive"/>
	</Pipeline>

	<Pipeline Pass="GenerateCommandGlareBlade">
		<ComputeShader Filename="PostProcessLensFlare.hlsl" EntryPoint="GenerateCommandGlareBladeCS" />
	</Pipeline>

	<Pipeline Pass="GatherBladePosition">
