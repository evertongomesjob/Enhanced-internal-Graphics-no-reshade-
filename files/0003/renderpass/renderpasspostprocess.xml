		<PixelShader Filename="PostProcessLensFlare.hlsl" EntryPoint="GlareBladesPS" />
		<InputElement Topology="PointList"/>
		<BlendState AlphaBlend="Additive"/>
	</Pipeline>

	<Pipeline Pass="LensFlareBladesIndirect" FrameBufferBindingName="LensFlare">
		<Define Name="USE_GATHER_POSITION" Value="1" CacheSuffix="ugp" TargetShaders="vs" Condition="!ps5"/>
		<Define Name="USE_GATHER_POSITION" Value="1" CacheSuffix="ugp" TargetShaders="gs" Condition="ps5"/>
		<VertexShader Filename="PostProcessLensFlare.hlsl" EntryPoint="GlareBladesVS" />
		<GeometryShader Filename="PostProcessLensFlare.hlsl" EntryPoint="GlareBladesGS" />
		<PixelShader Filename="PostProcessLensFlare.hlsl" EntryPoint="GlareBladesPS" />
		<InputElement Topology="PointList"/>
		<BlendState AlphaBlend="Additive"/>
