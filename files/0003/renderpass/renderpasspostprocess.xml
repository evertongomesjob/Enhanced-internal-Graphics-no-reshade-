		<PixelShader Filename="PostProcessPingPong.hlsl" EntryPoint="PreparePostProcessPointBlurPS" />
		<BlendState AlphaBlend="Additive_RG"/>
	</Pipeline>
	<Pipeline Pass="PreparePostProcessRadialBlur" InputLayout="FullScreenVertex" FrameBufferBindingName="DistortionOffset">
		<VertexShader Filename="ScreenSpaceCommon.hlsl" EntryPoint="FullScreenVS" />
		<PixelShader Filename="PostProcessPingPong.hlsl" EntryPoint="PreparePostProcessRadialBlurPS" />
		<BlendState AlphaBlend="Additive_RG"/>
	</Pipeline>
	
	<Pipeline Pass="LensFlareChroma" InputLayout="FullScreenVertex" FrameBufferBindingName="LensFlare">
		<VertexShader Filename="ScreenSpaceCommon.hlsl" EntryPoint="FullScreenVS" />
		<PixelShader Filename="PostProcessLensFlare.hlsl" EntryPoint="ChromaPS" />
	</Pipeline>

	<Pipeline Pass="LensFlareGhosts" InputLayout="FullScreenVertex" FrameBufferBindingName="LensFlare">
