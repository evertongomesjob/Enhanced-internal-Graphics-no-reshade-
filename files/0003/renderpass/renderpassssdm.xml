		<BlendState2 ColorWrite="RGBA" />
		<BlendState3 ColorWrite="RGBA" />
		<StencilState StencilEnable="True" StencilFunc="Always" PassOp="Replace" FailOp="Keep" DepthFailOp="Keep" StencilRefName="MATERIAL_ID_SSDM_CHARACTER"/>
