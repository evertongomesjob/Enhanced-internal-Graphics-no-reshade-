		<InputElement Topology="TriangleList">
			<VertexElement Element="Position" Format="R8_UINT" InputClass="Vertex"/>
		</InputElement>
		<DepthState DepthWrite="True" DepthEnable="True" DepthFunc="GreaterEqual"/>
	</Pipeline>

	<Pipeline Pass="SSDM_Background_Strip">
		<Define Name="SSDM_PASS" Value="0" CacheSuffix="sp" TargetShaders="all"/>
		<Define Name="USE_SSDM_FAR_GRASS" Value="0" CacheSuffix="usfg" TargetShaders="all"/>
		<Permutation>
			<Element Name="UseHeightScale" EnableMacroName="USE_HEIGHT_SCALE" EnumType="Bool" Default="True" CacheSuffix="uhs" TargetShaders="all" />
			<Element Name="ReorientDisplacedNormals" EnableMacroName="REORIENT_DISPLACED_NORMALS" EnumType="Bool" Default="True" CacheSuffix="rdn" TargetShaders="all" />
			<Element Name="UseNoInterpolationLookup" EnableMacroName="USE_NO_INTERPOLATION_LOOKUP" EnumType="Bool" Default="True" CacheSuffix="uni" TargetShaders="all" />
			<Element Name="ReprojectVertexNormalAndHeight" EnableMacroName="REPROJECT_VERTEX_NORMAL_AND_HEIGHT" EnumType="Bool" Default="False" CacheSuffix="rpvnh" TargetShaders="all" />
			<Element Name="UseRayReconstruction" EnableMacroName="USE_RAY_RECONSTRUCTION" EnumType="Bool" Default="True" CacheSuffix="urr" TargetShaders="all" />
			<!--<Element Name="UseSSDMFarGrass" EnableMacroName="USE_SSDM_FAR_GRASS" EnumType="Bool" Default="False" CacheSuffix="usfg" TargetShaders="all" />-->
		</Permutation>
		<VertexShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="SSDM_Background_StripVS"/>
		<PixelShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="SSDM_Background_TilePS"/>
		<BlendState ColorWrite="RGBA" />
		<BlendState1 ColorWrite="RGBA" />
		<BlendState2 ColorWrite="RGBA" />
		<BlendState3 ColorWrite="" />
		<BlendState4 ColorWrite="" />
		<StencilState StencilEnable="True" StencilFunc="Always" PassOp="Replace" FailOp="Keep" DepthFailOp="Keep" StencilRefName="MATERIAL_ID_SSDM_BACKGROUND"/>
		<CullMode Mode="Front"/>
		<InputElement Topology="TriangleStrip">
			<VertexElement Element="Position" Format="R32_UINT" InputClass="Vertex"/>
		</InputElement>
		<DepthState DepthWrite="True" DepthEnable="True" DepthFunc="GreaterEqual"/>
	</Pipeline>

	<Pipeline Pass="SSDM_Background_Tile_MS" Condition="MeshShader&ConditionalTrinity">
		<Define Name="SSDM_PASS" Value="0" CacheSuffix="sp" TargetShaders="all"/>
		<Define Name="USE_SSDM_FAR_GRASS" Value="0" CacheSuffix="usfg" TargetShaders="all"/>
		<Permutation>
			<Element Name="UseHeightScale" EnableMacroName="USE_HEIGHT_SCALE" EnumType="Bool" Default="True" CacheSuffix="uhs" TargetShaders="all" />
			<Element Name="ReorientDisplacedNormals" EnableMacroName="REORIENT_DISPLACED_NORMALS" EnumType="Bool" Default="True" CacheSuffix="rdn" TargetShaders="all" />
			<Element Name="ReprojectVertexNormalAndHeight" EnableMacroName="REPROJECT_VERTEX_NORMAL_AND_HEIGHT" EnumType="Bool" Default="False" CacheSuffix="rpvnh" TargetShaders="all" />
			<Element Name="UseRayReconstruction" EnableMacroName="USE_RAY_RECONSTRUCTION" EnumType="Bool" Default="True" CacheSuffix="urr" TargetShaders="all" />
			<!--<Element Name="UseSSDMFarGrass" EnableMacroName="USE_SSDM_FAR_GRASS" EnumType="Bool" Default="False" CacheSuffix="usfg" TargetShaders="all" />-->
		</Permutation>
		<MeshShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="SSDM_Common_TileMS"/>
		<PixelShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="SSDM_Background_TilePS"/>
		<BlendState ColorWrite="RGBA" />
		<BlendState1 ColorWrite="RGBA" />
		<BlendState2 ColorWrite="RGBA" />
		<BlendState3 ColorWrite="" />
		<BlendState4 ColorWrite="" />
		<StencilState StencilEnable="True" StencilFunc="Always" PassOp="Replace" FailOp="Keep" DepthFailOp="Keep" StencilRefName="MATERIAL_ID_SSDM_BACKGROUND"/>
		<DepthState DepthWrite="True" DepthEnable="True" DepthFunc="GreaterEqual"/>
	</Pipeline>

	<Pipeline Pass="SSDM_Background_FillHoles_DepthDisplacement" InputLayout="FullScreenVertex">
		<Permutation>
			<Element Name="GenerateBehindReconstructMask" EnableMacroName="GENERATE_BEHIND_RECONSTRUCT_MASK" EnumType="Bool" Default="False" CacheSuffix="gbrm" TargetShaders="all" />
		</Permutation>
		<Define Name="SSDM_PASS" Value="0" CacheSuffix="sp" TargetShaders="ps"/>
		<VertexShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="SSDM_FillHolesDepthDisplacementVS"/>
		<PixelShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="SSDM_FillHolesDepthDisplacementPS"/>
		<DepthState DepthWrite="True" DepthEnable="True" DepthFunc="GreaterEqual"/>
		<BlendState ColorWrite="RGBA" />
		<BlendState1 ColorWrite="RGBA" />
		<BlendState2 ColorWrite="RGBA" />
		<BlendState3 ColorWrite="" />
		<BlendState4 ColorWrite="" />
	</Pipeline>

	<Pipeline Pass="SSDM_Background_DilateBehindMaterials">
		<ComputeShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="SSDM_DilateBehindMaterialsCS" />
	</Pipeline>

	<Pipeline Pass="SSDM_Background_ReconstructBehindMaterials">
		<ComputeShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="SSDM_ReconstructBehindMaterialsCS" />
	</Pipeline>

	<Pipeline Pass="SSDM_Background_ReconstructBehindMaterialsPS" InputLayout="FullScreenVertex">
		<Permutation>
			<Element Name="UseHeightScale" EnableMacroName="USE_HEIGHT_SCALE" EnumType="Bool" Default="True" CacheSuffix="uhs" TargetShaders="all" />
		</Permutation>
		<VertexShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="FullScreenVS"/>
		<PixelShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="SSDM_ReconstructBehindMaterialsPS"/>
		<DepthState DepthWrite="True" DepthEnable="True" DepthFunc="Always"/>
		<BlendState ColorWrite="" />
		<BlendState1 ColorWrite="" />
		<BlendState2 ColorWrite="" />
	</Pipeline>
</RenderPass>

