<RenderPass Name="ScreenSpaceDisplacementMappingBackground" FrameBuffer="ScreenSpaceDisplacementMappingFrameBufferBackground" ClearTarget="RenderTargets">
	<Pipeline Pass="SSDM_Background" >
		<VertexShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="SSDM_BackgroundPass_VS"/>
		<PixelShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="SSDM_BackgroundPass_PS"/>
		<BlendState ColorWrite="RGBA" />
		<BlendState1 ColorWrite="RGBA" />
		<BlendState2 ColorWrite="RGBA" />
		<BlendState3 ColorWrite="" />
		<BlendState4 ColorWrite="" />
		<InputElement Topology="TriangleStrip">
			<VertexElement Element="Position" Format="R32_UINT" InputClass="Vertex"/>
		</InputElement>
	</Pipeline>

	<Pipeline Pass="SSDM_Background_Reconstructor" InputLayout="FullScreenVertex">
		<Define Name="SSDM_PASS" Value="0" CacheSuffix="sp" TargetShaders="ps"/>
		<Define Name="IS_BACKGROUND_ONLY_PASS" Value="1" CacheSuffix="bop" TargetShaders="ps"/>
		<Define Name="USE_SSDM_FAR_GRASS" Value="0" CacheSuffix="usfg" TargetShaders="all"/>
		<Permutation>
			<!--<Element Name="UseSSDMFarGrass" EnableMacroName="USE_SSDM_FAR_GRASS" EnumType="Bool" Default="False" CacheSuffix="usfg" TargetShaders="all" />-->
			<Element Name="GenerateBehindReconstructMask" EnableMacroName="GENERATE_BEHIND_RECONSTRUCT_MASK" EnumType="Bool" Default="False" CacheSuffix="gbrm" TargetShaders="all" />
		</Permutation>
		<VertexShader Filename="ScreenSpaceCommon.hlsl" EntryPoint="FullScreenVS"/>
		<PixelShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="SSDM_ReconstructorPS"/>
		<BlendState ColorWrite="RGBA" />
		<BlendState1 ColorWrite="RGBA" />
		<BlendState2 ColorWrite="RGBA" />
		<BlendState3 ColorWrite="" />
		<BlendState4 ColorWrite="" />
		<StencilState StencilEnable="True" StencilFunc="Always" PassOp="Replace" FailOp="Keep" DepthFailOp="Keep" StencilRefName="MATERIAL_ID_SSDM_BACKGROUND"/>
	</Pipeline>

	<Pipeline Pass="SSDM_Background_DilateBehindMaterials" InputLayout="FullScreenVertex">
		<ComputeShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="SSDM_DilateBehindMaterialsCS" />
	</Pipeline>

	<Pipeline Pass="SSDM_Background_ReconstructBehindMaterials" InputLayout="FullScreenVertex">
		<ComputeShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="SSDM_ReconstructBehindMaterialsCS" />
	</Pipeline>

	<Pipeline Pass="SSDM_Background_FillHoles" InputLayout="FullScreenVertex">
		<Define Name="SSDM_PASS" Value="0" CacheSuffix="sp" TargetShaders="ps"/>
		<VertexShader Filename="ScreenSpaceCommon.hlsl" EntryPoint="FullScreenVS"/>
		<PixelShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="SSDM_FillHolesPS"/>
		<BlendState ColorWrite="RGBA" />
		<BlendState1 ColorWrite="RGBA" />
		<BlendState2 ColorWrite="RGBA" />
		<BlendState3 ColorWrite="" />
		<BlendState4 ColorWrite="" />
		<DepthState DepthWrite="False" DepthEnable="False"/>
		<StencilState StencilEnable="True" StencilFunc="NotEqual" ReadMaskName="MATERIAL_ID_MASK" PassOp="Keep" FailOp="Keep" DepthFailOp="Keep" StencilRefName="MATERIAL_ID_SSDM_BACKGROUND"/>
	</Pipeline>
</RenderPass>

