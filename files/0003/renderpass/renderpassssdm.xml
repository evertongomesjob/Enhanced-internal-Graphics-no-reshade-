</FrameBuffer>

<RenderPass Name="CopyStencil" FrameBuffer="CopyStencilFrameBuffer" ClearTarget="All">
	<Pipeline Pass="CopyStencilPass" InputLayout="FullScreenVertex">
		<VertexShader Filename="ScreenSpaceCommon.hlsl" EntryPoint="FullScreenVS" />
		<PixelShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="CopyStencilPS"/>
		<DepthState DepthWrite="False" DepthEnable="False"/>
	</Pipeline>
</RenderPass>

<RenderPass Name="CopyEffectMaterialID">
	<Pipeline Pass="CopyEffectMaterialIDPass">
		<ComputeShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="CopyEffectMaterialID_CS" />
	</Pipeline>
</RenderPass>

<RenderPass Name="ScreenSpaceDisplacementMappingCopyBackBackground" FrameBuffer="SSDMCopyBackFrameBufferBackground">
	<Pipeline Pass="CopySSDMToGbufferBackground" InputLayout="FullScreenVertex">
		<VertexShader Filename="ScreenSpaceCommon.hlsl" EntryPoint="FullScreenVS"/>
		<PixelShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="CopySSDMToGbufferBackgroundPS"/>
		<DepthState DepthWrite="False" DepthEnable="False"/>
		<StencilState StencilEnable="True" StencilFunc="Equal" ReadMaskName="MATERIAL_ID_MASK" WriteMask="0" StencilRefName="MATERIAL_ID_SSDM_BACKGROUND"/>
	</Pipeline>
</RenderPass>

<RenderPass Name="ScreenSpaceDisplacementMappingCopyBackCharacter" FrameBuffer="SSDMCopyBackFrameBufferCharacter">
	<Pipeline Pass="CopySSDMToGbufferCharacter" InputLayout="FullScreenVertex">
		<VertexShader Filename="ScreenSpaceCommon.hlsl" EntryPoint="FullScreenVS"/>
		<PixelShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="CopySSDMToGbufferCharacterPS"/>
		<DepthState DepthWrite="False" DepthEnable="False"/>
		<StencilState StencilEnable="True" StencilFunc="Equal" ReadMaskName="MATERIAL_ID_MASK" WriteMask="0" StencilRefName="MATERIAL_ID_SSDM_CHARACTER"/>
	</Pipeline>
</RenderPass>

<RenderPass Name="ScreenSpaceDisplacementMappingCopyBack" FrameBuffer="SSDMCopyBackFrameBufferCharacter">
	<Pipeline Pass="CopyBackgroundSSDMToGbuffer" InputLayout="FullScreenVertex">
		<VertexShader Filename="ScreenSpaceCommon.hlsl" EntryPoint="FullScreenVS"/>
		<PixelShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="CopyBackgroundSSDMToGbufferPS"/>
		<DepthState DepthWrite="False" DepthEnable="False"/>
		<BlendState2 ColorWrite="" />
		<BlendState3 ColorWrite="" />
	</Pipeline>

	<Pipeline Pass="CopyCharacterSSDMToGbuffer" InputLayout="FullScreenVertex">
		<VertexShader Filename="ScreenSpaceCommon.hlsl" EntryPoint="FullScreenVS"/>
		<PixelShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="CopyCharacterSSDMToGbufferPS"/>
	</Pipeline>
</RenderPass>

<RenderPass Name="CopyStencilSSDM" FrameBuffer="CopyStencilSSDM" >
	<Pipeline Pass="CopyStencilBackground" InputLayout="FullScreenVertex">
		<VertexShader Filename="ScreenSpaceCommon.hlsl" EntryPoint="FullScreenVS"/>
		<PixelShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="CopyStencilSSDMBackgroundPS"/>
		<DepthState DepthWrite="False" DepthEnable="False"/>
		<StencilState StencilEnable="True" StencilFunc="NotEqual" ReadMaskName="MATERIAL_ID_MASK" WriteMask="0" StencilRefName="MATERIAL_ID_SSDM_BACKGROUND"/>
	</Pipeline>
	<Pipeline Pass="CopyStencilCharacter" InputLayout="FullScreenVertex">
		<VertexShader Filename="ScreenSpaceCommon.hlsl" EntryPoint="FullScreenVS"/>
		<PixelShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="CopyStencilSSDMCharacterPS"/>
		<DepthState DepthWrite="False" DepthEnable="False"/>
		<StencilState StencilEnable="True" StencilFunc="NotEqual" ReadMaskName="MATERIAL_ID_MASK" WriteMask="0" StencilRefName="MATERIAL_ID_SSDM_CHARACTER"/>
	</Pipeline>
</RenderPass>

<RenderPass Name="ScreenSpaceDisplacementMappingInstancing" >
	<Pipeline Pass="ResetCounterBuffer" >
		<ComputeShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="ResetCounterBufferCS" />
	</Pipeline>

	<Pipeline Pass="GenerateTiledMask" >
		<ComputeShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="GenerateMaskTextureCS" />
	</Pipeline>

	<Pipeline Pass="ClearInstancingBuffer" >
		<ComputeShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="ClearInstancingBufferCS" />
	</Pipeline>

	<Pipeline Pass="GenerateInstancingBuffer" >    
		<ComputeShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="GenerateInstancingBufferCS" />
	</Pipeline>

	<Pipeline Pass="GenerateIndirectCommand" Condition="IndirectCommand">
		<ComputeShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="GenerateIndirectCommandCS" />
	</Pipeline>
</RenderPass>

<RenderPass Name="ScreenSpaceDisplacementMappingRasterizer" >
	<Pipeline Pass="ResetCounterBuffer" >
		<ComputeShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="ResetCounterBufferCS" />
	</Pipeline>

	<Pipeline Pass="ClearRasterizerBuffer" >
		<ComputeShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="ClearRasterizerBufferCS" />
	</Pipeline>

	<Pipeline Pass="SSDM_Background_SoftwareRasterizer" >
		<Define Name="SSDM_PASS" Value="0" CacheSuffix="sp" TargetShaders="cs"/>
		<Define Name="IS_SOFTWARE_RASTERIZER" Value="1" CacheSuffix="sr" TargetShaders="cs"/>
		<Define Name="USE_SSDM_FAR_GRASS" Value="0" CacheSuffix="usfg" TargetShaders="all"/>
		<Permutation>
			<!--<Element Name="UseSSDMFarGrass" EnableMacroName="USE_SSDM_FAR_GRASS" EnumType="Bool" Default="False" CacheSuffix="usfg" TargetShaders="all" />-->
			<Element Name="CopyGBuffers" EnableMacroName="COPY_GBUFFERS" EnumType="Bool" Default="False" CacheSuffix="cgb" TargetShaders="cs" />
			<Element Name="CalcHalf" EnableMacroName="CALC_HALF" EnumType="Bool" Default="True" CacheSuffix="cch" TargetShaders="cs" />
		</Permutation>
		<ComputeShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="SoftwareRasterizerSSDMCS" />
	</Pipeline>

	<Pipeline Pass="SSDM_Character_SoftwareRasterizer" >
		<Define Name="SSDM_PASS" Value="1" CacheSuffix="sp" TargetShaders="cs"/>
		<Define Name="IS_SOFTWARE_RASTERIZER" Value="1" CacheSuffix="sr" TargetShaders="cs"/>
		<Permutation>
			<Element Name="SSDMDirection" EnableMacroName="USE_CHARATER_SSDM_DIRECTION" EnumType="Bool" Default="False" CacheSuffix="csd" TargetShaders="all"/>
			<Element Name="CalcHalf" EnableMacroName="CALC_HALF" EnumType="Bool" Default="True" CacheSuffix="cch" TargetShaders="cs" />
		</Permutation>
		<ComputeShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="SoftwareRasterizerSSDMCS" />
	</Pipeline>

	<Pipeline Pass="GenerateIndirectCommandHardwareRasterizer" >
		<ComputeShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="GenerateIndirectCommandHardwareRasterizerCS" />
	</Pipeline>
</RenderPass>

<RenderPass Name="HardwareRasterizeTriangle" FrameBuffer="SSDMDepthOnly" Condition="MeshShader">
	<!--<Define Name="XBOX" Value="1" CacheSuffix="xb" TargetShaders="all" Condition="Xbox"/>-->
	<Pipeline Pass="SSDM_Background_HardwareRasterizeTriangle">
		<Define Name="SSDM_PASS" Value="0" CacheSuffix="sp" TargetShaders="all"/>
		<Define Name="USE_SSDM_FAR_GRASS" Value="0" CacheSuffix="usfg" TargetShaders="all"/>
		<Permutation>
			<!--<Element Name="UseSSDMFarGrass" EnableMacroName="USE_SSDM_FAR_GRASS" EnumType="Bool" Default="False" CacheSuffix="usfg" TargetShaders="all" />-->
		</Permutation>
		<MeshShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="HardwareRasterizeTriangleMS"/>
		<PixelShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="HardwareRasterizeTrianglePS"/>
		<DepthState DepthWrite="False" DepthEnable="False"/>
	</Pipeline>

	<Pipeline Pass="SSDM_Character_HardwareRasterizeTriangle" >
		<Define Name="SSDM_PASS" Value="1" CacheSuffix="sp" TargetShaders="all"/>
		<Permutation>
			<Element Name="SSDMDirection" EnableMacroName="USE_CHARATER_SSDM_DIRECTION" EnumType="Bool" Default="False" CacheSuffix="csd" TargetShaders="all"/>
		</Permutation>
		<MeshShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="HardwareRasterizeTriangleMS"/>
		<PixelShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="HardwareRasterizeTrianglePS"/>
		<DepthState DepthWrite="False" DepthEnable="False"/>
	</Pipeline>
</RenderPass>

<RenderPass Name="ScreenSpaceDisplacementMappingTileMask" >
	<Pipeline Pass="GenerateTileMaskBackground" >
		<Permutation>
			<Element Name="IsTiledCS" EnableMacroName="IS_TILED" EnumType="Bool" Default="True" CacheSuffix="tile" TargetShaders="cs" />
		</Permutation>
		<Define Name="SSDM_PASS" Value="0" CacheSuffix="sp" TargetShaders="cs"/>
		<ComputeShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="GenerateTileMaskCS" />
	</Pipeline>

	<Pipeline Pass="GenerateTileMaskCharacter" >
		<Permutation>
			<Element Name="IsTiledCS" EnableMacroName="IS_TILED" EnumType="Bool" Default="True" CacheSuffix="tile" TargetShaders="cs" />
		</Permutation>
		<Define Name="SSDM_PASS" Value="1" CacheSuffix="sp" TargetShaders="cs"/>
		<ComputeShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="GenerateTileMaskCS" />
	</Pipeline>

	<Pipeline Pass="ResetCounterBuffer" >
		<ComputeShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="ResetCounterBufferCS" />
	</Pipeline>

	<Pipeline Pass="GenerateCharacterTilesBuffer" >
		<ComputeShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="GenerateCharacterTilesBufferCS" />
	</Pipeline>

	<Pipeline Pass="GenerateIndirectCommandCharacterTiles" >
		<ComputeShader Filename="ScreenSpaceTessellation.hlsl" EntryPoint="GenerateIndirectCommandCharacterTilesCS" />
	</Pipeline>
</RenderPass>
