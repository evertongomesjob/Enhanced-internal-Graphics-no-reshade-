<RenderPass Name="RenderParticlesAlphaBlend" FrameBuffer="EffectAlphaBlendFrameBuffer" Condition="MultiDraw">
	<Pipeline Pass="EffectMaterial" InputLayout="EffectVertex" Condition="ConditionalVRS">
		<Permutation>			
			<!-- NOTE: enum class EFfectDepthStencilOptions과 동일하게 유지할것!! -->
			<!-- NOTE: EffectConstant.hlsl과 동일하게 유지할것!! -->
			<Element Name="AMPLIFIED_GLARE_MODE" Default="0" EnableMacroName="AMPLIFIED_GLARE_MODE" EnumType="Integer" Count="2" CacheSuffix="ag" TargetShaders="vs|ps" Material="true"  Mutable="False">
				<PipelineState Type="Blank"/>
				<PipelineState Type="Overwrite">
					<StencilState StencilEnable="True" StencilFunc="Always" PassOp="Replace" FailOp="Keep" DepthFailOp="Keep" WriteMaskName="MATERIAL_ID_MASK" StencilRefName="MATERIAL_ID_AMPLIFIED_GLARE_PARTICLE" />
				</PipelineState>
			</Element>
			<Element Name="EFFECT_DEPTH_STENCIL_OPTIONS" EnableMacroName="EFFECT_DEPTH_STENCIL_OPTIONS" EnumType="Integer" Default="0" Count="3" Mutable="False" CacheSuffix="dsop" TargetShaders="vs|ps" Material="true">
				<PipelineState Type="Blank" />
				<PipelineState Type="Overwrite">
					<DepthState DepthEnable="True" DepthWrite="True" />
				</PipelineState>
				<PipelineState Type="Overwrite">
					<DepthState DepthEnable="False" DepthWrite="False" />
				</PipelineState>
			</Element>
			<Element Name="IS_COMMON_EFFECT" EnableMacroName="IS_COMMON_EFFECT" EnumType="Bool" Default="True" CacheSuffix="ce" TargetShaders="vs|ps" Material="true">
				<Overriding Value="False" BuildTriggerType="Deferred">
					<StencilState StencilEnable="False" />
				</Overriding>
				<Overriding Value="True" BuildTriggerType="Preloading"/>
			</Element>
			<Element Name="PARTICLE_RENDER_SHAPE" EnableMacroName="PARTICLE_RENDER_SHAPE" EnumType="Integer" Default="0" Count="2" Mutable="False" CacheSuffix="rs" TargetShaders="vs|ps" Material="true">
				<PipelineState Type="Blank"></PipelineState>
				<PipelineState Type="Overwrite">
					<DepthState DepthWrite="False" DepthFunc="LessEqual" />
					<StencilState StencilEnable="False"/>
					<!--<CullMode Mode="Front" /> 데칼을 음수 스케일로 좌우 반전시 컬링되는 문제가 있어 주석처리-->
				</PipelineState>
			</Element>
			<Element Name="BLEND_MODE" Default="0" EnableMacroName="BLEND_MODE" EnumType="Integer" Count="2" Mutable="False" CacheSuffix="bm" TargetShaders="vs|ps" Material="true">
				<PipelineState Type="Overwrite">
					<BlendState AlphaBlend="PremultipliedAlphaAccumulateInvSrc1Alpha"/>
				</PipelineState>
				<PipelineState Type="Overwrite">
					<BlendState AlphaBlend="AdditiveAccumulateInvAlpha"/>
				</PipelineState>
			</Element>
			<Element Name="UNFILTERED_MODE" Default="0" EnableMacroName="UNFILTERED_MODE" EnumType="Integer" Count="2" CacheSuffix="uf" TargetShaders="vs|ps" Material="true">
				<PipelineState Type="Blank"/>
				<PipelineState Type="Overwrite">
					<StencilState StencilEnable="True" StencilFunc="Always" PassOp="Replace" FailOp="Keep" DepthFailOp="Keep" WriteMaskName="MATERIAL_ID_MASK" StencilRefName="MATERIAL_ID_UNFILTERED_TRANSLUCENT_PARTICLE" />
				</PipelineState>
			</Element>
		</Permutation>
		<BlendState  ColorWrite="RGBA" />
		<BlendState1 ColorWrite="RGBA" />
		<Define Name="EFFECT_RENDER_MODE" Value="0" CacheSuffix="rm" TargetShaders="vs|ps" />
		<VertexShader Filename="EffectMaterial.hlsl" EntryPoint="RenderGPUParticles_VS" />
		<PixelShader Filename="EffectMaterial.hlsl" EntryPoint="RenderGPUParticles_PS" />
		<DepthState DepthEnable="True" DepthWrite="False" />
		<StencilState StencilEnable="True" StencilFunc="Always" PassOp="Replace" FailOp="Keep" DepthFailOp="Keep" WriteMaskName="MATERIAL_ID_MASK" StencilRefName="MATERIAL_ID_TRANSLUCENT_PARTICLE" />
		<CullMode Mode="None" />
	</Pipeline>
</RenderPass>

